{
  "name": "node-env-resolver",
  "version": "6.4.0",
  "description": "Type-safe environment variable resolver with async resolvers - lightweight, tree-shakeable, no dependencies",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "node-env-resolver": "./dist/cli-main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./builder": {
      "types": "./dist/builder.d.ts",
      "import": "./dist/builder.js",
      "require": "./dist/builder.cjs",
      "default": "./dist/builder.js"
    },
    "./zod": {
      "types": "./dist/zod.d.ts",
      "import": "./dist/zod.js",
      "require": "./dist/zod.cjs",
      "default": "./dist/zod.js"
    },
    "./valibot": {
      "types": "./dist/valibot.d.ts",
      "import": "./dist/valibot.js",
      "require": "./dist/valibot.cjs",
      "default": "./dist/valibot.js"
    },
    "./web": {
      "types": "./dist/web.d.ts",
      "import": "./dist/web.js",
      "require": "./dist/web.cjs",
      "default": "./dist/web.js"
    },
    "./resolvers": {
      "types": "./dist/resolvers.d.ts",
      "import": "./dist/resolvers.js",
      "require": "./dist/resolvers.cjs",
      "default": "./dist/resolvers.js"
    },
    "./validators": {
      "types": "./dist/validators.d.ts",
      "import": "./dist/validators.js",
      "require": "./dist/validators.cjs",
      "default": "./dist/validators.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js",
      "require": "./dist/utils.cjs",
      "default": "./dist/utils.js"
    },
    "./redaction": {
      "types": "./dist/redaction.d.ts",
      "import": "./dist/redaction.js",
      "require": "./dist/redaction.cjs",
      "default": "./dist/redaction.js"
    },
    "./typegen": {
      "types": "./dist/typegen.d.ts",
      "import": "./dist/typegen.js",
      "require": "./dist/typegen.cjs",
      "default": "./dist/typegen.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js",
      "require": "./dist/cli.cjs",
      "default": "./dist/cli.js"
    },
    "./audit": {
      "types": "./dist/audit.d.ts",
      "import": "./dist/audit.js",
      "require": "./dist/audit.cjs",
      "default": "./dist/audit.js"
    },
    "./resolver": {
      "types": "./dist/resolver.d.ts",
      "import": "./dist/resolver.js",
      "require": "./dist/resolver.cjs",
      "default": "./dist/resolver.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs",
      "default": "./dist/types.js"
    }
  },
  "typesVersions": {
    "*": {
      "resolvers": [
        "./dist/resolvers.d.ts"
      ],
      "validators": [
        "./dist/validators.d.ts"
      ],
      "utils": [
        "./dist/utils.d.ts"
      ],
      "redaction": [
        "./dist/redaction.d.ts"
      ],
      "typegen": [
        "./dist/typegen.d.ts"
      ],
      "builder": [
        "./dist/builder.d.ts"
      ],
      "zod": [
        "./dist/zod.d.ts"
      ],
      "valibot": [
        "./dist/valibot.d.ts"
      ],
      "web": [
        "./dist/web.d.ts"
      ],
      "cli": [
        "./dist/cli.d.ts"
      ],
      "audit": [
        "./dist/audit.d.ts"
      ],
      "resolver": [
        "./dist/resolver.d.ts"
      ],
      "types": [
        "./dist/types.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "NODE_ENV=production tsup",
    "build:dev": "tsup",
    "build:dts": "tsc --emitDeclarationOnly",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prepublishOnly": "pnpm build && pnpm type-check"
  },
  "keywords": [
    "environment",
    "env",
    "config",
    "typescript",
    "aws-secrets",
    "aws-ssm",
    "vault",
    "doppler",
    "type-safe",
    "tree-shaking",
    "lambda",
    "serverless"
  ],
  "author": {
    "name": "Jagvinder Singh Reehal",
    "email": "jag@jagreehal.com",
    "url": "https://jagreehal.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jagreehal/node-env-resolver.git",
    "directory": "packages/node-env-resolver"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "ansis": "^4.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-zod": "^1.2.1",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
