{
  "name": "node-env-resolver",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean",
    "dev": "dotenv -- turbo run dev --no-cache --parallel --continue",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "lint:exports": "eslint --ext .ts,.js packages/*/src/index.ts packages/*/src/index.js",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "example:basic": "pnpm --filter simple-example dev",
    "example:express": "pnpm --filter express-app-example dev",
    "example:lambda": "pnpm --filter aws-lambda-example dev",
    "release": "pnpm changeset publish --provenance --access public",
    "quality": "turbo run build lint type-check test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.16"
  },
  "packageManager": "pnpm@10.26.0",
  "dependencies": {
    "@changesets/cli": "^2.30.0"
  }
}
